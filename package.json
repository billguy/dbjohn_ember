{
  "name": "dbjohn-ember",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for dbjohn-ember goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/eslint-parser": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@ember/optional-features": "^2.2.0",
    "@ember/render-modifiers": "^4.0.0",
    "@ember/test-helpers": "^5.3.0",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.19.1",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.37.0",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@rollup/plugin-babel": "^6.1.0",
    "active-model-adapter": "5.0.0",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "bootstrap": "^5.3.3",
    "concurrently": "^9.1.2",
    "dayjs": "^1.11.0",
    "decorator-transforms": "^2.3.1",
    "ember-bootstrap": "^6.4.2",
    "ember-cli": "~6.8.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-cli-dotenv": "^4.0.0",
    "ember-cli-flash": "^6.0.0",
    "ember-cli-htmlbars": "^6.3.0",
    "@warp-drive/core": "~5.8.1",
    "@warp-drive/ember": "~5.8.1",
    "@warp-drive/json-api": "~5.8.1",
    "@warp-drive/legacy": "~5.8.1",
    "@warp-drive/utilities": "~5.8.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.2.0",
    "ember-page-title": "^9.0.1",
    "ember-bootstrap-cp-validations": "^2.1.0",
    "ember-cp-validations": "^7.0.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.1.0",
    "ember-simple-auth": "^8.0.0",
    "ember-simple-auth-token": "^6.0.1",
    "ember-source": "~6.8.0",
    "ember-tag-input": "^3.1.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.4",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-qunit": "^8.1.2",
    "globals": "^17.4.0",
    "placeholder-loading": "^0.7.0",
    "prettier": "^3.5.3",
    "prettier-plugin-ember-template-tag": "^2.0.5",
    "quill": "^2.0.0",
    "qunit": "^2.24.2",
    "qunit-dom": "^3.4.0",
    "sass": "^1.79.4",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^36.0.1",
    "tracked-built-ins": "^4.1.2",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": "24.x"
  },
  "ember": {
    "edition": "octane"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "dependencies": {
    "spark-md5": "^3.0.2"
  }
}
