{{page-title this.model.title}}

<div class="d-flex justify-content-between pic-header" {{did-insert this.didInsert}}>
  <LinkTo @route="pics.show" @model={{this.model.prevPermalink}}>
    <img src={{this.model.prevThumbUrl}} alt={{this.model.prevPermalink}} height="100" width="100" />
  </LinkTo>

  <div class="d-none d-sm-block">
    {{#if this.model.hasCoords}}
      <GoogleMap @lat={{this.model.lat}} @lng={{this.model.lng}} @zoom={{10}} @onMarkerClick={{fn this.markerClicked this.model}} />
    {{else}}
      <div class="h4 hidden-xs text-muted text-center content map">Map Unavailable</div>
    {{/if}}
  </div>

  <LinkTo @route="pics.show" @model={{this.model.nextPermalink}}>
    <img src={{this.model.nextThumbUrl}} alt={{this.model.nextPermalink}} height="100" width="100" />
  </LinkTo>
</div>

<figure id="subject" class="cap-bot">
  <a href={{this.model.src}}>
    <img class="img-fluid" src={{this.model.src}} alt={{this.model.title}} />
    <figcaption>
      <PicCaption @pic={{this.model}} />
    </figcaption>
  </a>
</figure>

<div class="float-left">
  <h1>{{this.model.title}}</h1>
  <ul class="list-inline list-unstyled tags">
    {{#each this.model.tags as |tag|}}
      <li>
        <LinkTo @route="pics" @query={{hash tags=tag.name}}>
          {{tag.name}}
          <span>{{tag.taggings_count}}</span>
        </LinkTo>
      </li>
    {{/each}}
  </ul>
</div>

<div class="float-right">
  {{#if this.session.isAuthenticated}}
    <BsModalSimple
      @title="Please confirm"
      @renderInPlace={{true}}
      @closeTitle="Cancel"
      @submitTitle="Confirm"
      @open={{this.shouldDelete}}
      @onSubmit={{fn this.deletePic this.model}}
      @onHide={{fn this.setShouldDelete false}}
    >
      <p>You're about to delete '{{this.model.title}}'. Are you sure?</p>
    </BsModalSimple>

    <div class="float-right">
      <LinkTo @route="pics.edit" @model={{this.model}}>edit</LinkTo>
      <span>&nbsp;|&nbsp;</span>
      <span class="text-danger" style="cursor: pointer" {{on "click" (fn this.setShouldDelete true)}}>delete</span>
    </div>
  {{/if}}
</div>

<div class="clearfix"></div>

<p>{{this.model.caption}}</p>

<br />

{{!-- <DisqusComments @identifier={{this.model.discusIdentifier}} /> --}}
