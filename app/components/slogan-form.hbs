<BsForm @model={{this.args.model}} @multipart={{true}} @onSubmit={{this.submit}} as |form|>
  <form.element @label="Title" @controlType="text" @property="title" />
  <form.submitButton>
    {{#if form.isSubmitting}}
      <span>Please wait...</span>
    {{else}}
      <span>Submit</span>
    {{/if}}
  </form.submitButton>
</BsForm>
